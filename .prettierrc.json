{
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": false,
    "printWidth": 150,
    "tabWidth": 4,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "always",
    "overrides": [
      {
        "files": ["*.yml", "*.yaml"],
        "options": {
          "parser": "yaml",
          "tabWidth": 2
        }
        
      }
    ]
}