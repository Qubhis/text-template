{
    "name": "text-template",
    "version": "1.0.0",
    "description": "text template app",
    "private": true,
    "scripts": {
        "build": "npm run clean && npm run build:backend && npm run build:frontend && npm run postBuild:frontend",
        "build:backend": "tsc -p tsconfig.backend.json",
        "build:frontend": "tsc -p tsconfig.frontend.json",
        "postBuild:frontend": "cp -r src/frontend/* ./dist/frontend",
        "start": "node dist/backend/server.js",
        "start:prod": "NODE_ENV=production node dist/backend/server.js",
        "dev": "npm run build && node dist/backend/server.js",
        "dev:build": "tsc --watch",
        "clean": "rm -rf dist",
        "clean:deep": "rm -rf dist node_modules package-lock.json && npm install",
        "type-check": "npm run type-check:backend && npm run type-check:frontend",
        "type-check:backend": "tsc -p tsconfig.backend.json --noEmit",
        "type-check:frontend": "tsc -p tsconfig.frontend.json --noEmit",
        "lint": "echo 'Linting not configured yet'",
        "test": "echo 'Tests not configured yet'",
        "validate": "npm run type-check && npm run lint && npm run test",
        "prebuild": "npm run validate",
        "docker:build": "docker build -t text-template ."
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^5.1.0",
        "typescript": "^5.8.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/node": "^24.0.7",
        "prettier": "^3.6.2",
        "tsx": "^4.20.3"
    }
}
